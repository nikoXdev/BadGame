  m_Script: {fileID: 11500000, guid: 608fbe7b2db04780a7f9a269398e1137, type: 3}
  m_Name: LastDialogueData
  m_EditorClassIdentifier: Gameplay::Sources.Runtime.Gameplay.DialogueData
  <Contents>k__BackingField:
  - My superiors are <shake>very interested</shake> in your performance.
  - Every gummy you eliminate leaves behind <color=#FFD700><b>MARMALADE.</b></color>
  - Collect <color=#FF6B00><b><size=130%>1234 MARMALADE</size></b></color> and I'll
    <wiggle><color=#88FF88>personally</color></wiggle> ensure your release.
  - <wave><color=#C0C0C0><i>The train won't wait. Get to work.</i></color></wave>
